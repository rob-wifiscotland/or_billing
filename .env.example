# PostgreSQL connection
BILLING_DB_DSN=postgresql://user:password@localhost:5432/postgis_db

# File processing locations
BILLING_INPUT_DIR=/absolute/path/to/repo/incoming
BILLING_PROCESSED_DIR=/absolute/path/to/repo/processed
BILLING_FAILED_DIR=/absolute/path/to/repo/failed

# Psycopg pool settings
BILLING_DB_MIN_POOL=1
BILLING_DB_MAX_POOL=5

# Logging
BILLING_LOG_LEVEL=INFO
BILLING_LOG_FILE=/absolute/path/to/repo/logs/billing_parser.log

# Product account mappings (CUSTOMERRECORD column 3)
DARK_FIBRE=GM55832348
ETHERNET=GM55832131
GEA=GM55832127
LLU_CABLELINK=
LLU_UNBUNDLING=GM55832368
ACCESS_LOCATE=GM55832128
PIA=GM55832129
SOGEA=GM55832382
WLR=
